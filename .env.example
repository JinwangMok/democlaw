# =============================================================================
# DemoClaw — Environment Configuration
# =============================================================================
# Copy this file to .env and edit as needed:
#   cp .env.example .env
#
# All values below show their defaults. Uncomment and modify to override.
# The .env file is automatically loaded by start.sh, start-vllm.sh, and
# start-openclaw.sh.
# =============================================================================

# -----------------------------------------------------------------------------
# Container Runtime
# -----------------------------------------------------------------------------
# Force a specific container runtime. If unset, the scripts auto-detect
# in order: docker, then podman.
# Valid values: docker | podman
#CONTAINER_RUNTIME=docker

# -----------------------------------------------------------------------------
# Network
# -----------------------------------------------------------------------------
# Name of the shared container network connecting vLLM and OpenClaw.
#DEMOCLAW_NETWORK=democlaw-net

# -----------------------------------------------------------------------------
# vLLM Server — Model Configuration
# -----------------------------------------------------------------------------
# HuggingFace model identifier. Must be an AWQ 4-bit quantized model to fit
# within the 8 GB VRAM budget.
#MODEL_NAME=Qwen/Qwen2.5-7B-Instruct-AWQ

# Quantization method used by vLLM (must match the model format).
#QUANTIZATION=awq

# Data type for model weights.
#DTYPE=float16

# Maximum sequence length (context window). Lower values reduce VRAM usage.
#MAX_MODEL_LEN=8192

# Fraction of GPU memory vLLM is allowed to use (0.0–1.0).
#GPU_MEMORY_UTILIZATION=0.90

# -----------------------------------------------------------------------------
# vLLM Server — Container Settings
# -----------------------------------------------------------------------------
# Container name for the vLLM service.
#VLLM_CONTAINER_NAME=democlaw-vllm

# Docker/Podman image tag for the vLLM container.
#VLLM_IMAGE_TAG=democlaw/vllm:latest

# Port the vLLM server listens on inside the container.
#VLLM_PORT=8000

# Port published on the host for direct access to the vLLM API.
#VLLM_HOST_PORT=8000

# Timeout (seconds) to wait for vLLM /health endpoint during startup.
#VLLM_HEALTH_TIMEOUT=300

# Set to "true" to skip the model pre-pull step (e.g. weights already cached).
# Useful for offline environments or when you have already downloaded the model.
#SKIP_MODEL_PULL=false

# -----------------------------------------------------------------------------
# HuggingFace
# -----------------------------------------------------------------------------
# Host directory used to cache downloaded model weights. Mounted into the
# vLLM container so models are not re-downloaded on every restart.
#HF_CACHE_DIR=${HOME}/.cache/huggingface

# HuggingFace access token — required only for gated models.
# Get yours at https://huggingface.co/settings/tokens
#HF_TOKEN=

# -----------------------------------------------------------------------------
# OpenClaw — Container Settings
# -----------------------------------------------------------------------------
# Container name for the OpenClaw service.
#OPENCLAW_CONTAINER_NAME=democlaw-openclaw

# Docker/Podman image tag for the OpenClaw container.
#OPENCLAW_IMAGE_TAG=democlaw/openclaw:latest

# Port the OpenClaw dashboard listens on inside the container.
#OPENCLAW_PORT=18789

# Port published on the host for accessing the OpenClaw web dashboard.
# Visit http://localhost:18789 after startup.
#OPENCLAW_HOST_PORT=18789

# Timeout (seconds) to wait for the OpenClaw dashboard during startup.
#OPENCLAW_HEALTH_TIMEOUT=120

# -----------------------------------------------------------------------------
# OpenClaw — LLM Provider Connection
# -----------------------------------------------------------------------------
# Base URL of the vLLM OpenAI-compatible API endpoint (container-internal).
# Uses the container hostname "vllm" on the shared network.
#VLLM_BASE_URL=http://vllm:8000/v1

# API key for the vLLM OpenAI-compatible endpoint.
#
# When unset, empty, or set to "EMPTY" / "none":
#   The vLLM server runs in NO-AUTH mode. Every request is accepted regardless
#   of the Authorization header. This is the default — safe on a private
#   container network (democlaw-net) that is not exposed to the internet.
#
# When set to a real secret (e.g. VLLM_API_KEY=mysecret):
#   The vLLM server requires "Authorization: Bearer mysecret" on every request.
#   Set openclaw/config.json "apiKey" (or OPENCLAW_LLM_API_KEY) to the same value.
#
# The value is passed through to the container via -e VLLM_API_KEY=...
# and consumed by vllm/entrypoint.sh which adds --api-key to the vLLM command.
#VLLM_API_KEY=EMPTY

# Model name to request from vLLM. Must match MODEL_NAME above.
#VLLM_MODEL_NAME=Qwen/Qwen2.5-7B-Instruct-AWQ

# Maximum tokens per LLM response.
#VLLM_MAX_TOKENS=4096

# Sampling temperature for LLM responses (0.0 = deterministic, higher = more random).
#VLLM_TEMPERATURE=0.7

# Number of retries when OpenClaw waits for vLLM to become available at startup.
#VLLM_HEALTH_RETRIES=60

# Seconds between each vLLM readiness check from the OpenClaw container.
#VLLM_HEALTH_INTERVAL=5

# -----------------------------------------------------------------------------
# Healthcheck Script (scripts/healthcheck.sh)
# -----------------------------------------------------------------------------
# Timeout (seconds) for individual curl requests during health checks.
#HEALTHCHECK_CURL_TIMEOUT=10

# Number of retries for OpenClaw dashboard health checks.
#OPENCLAW_HEALTH_RETRIES=10

# Seconds between OpenClaw dashboard health check retries.
#OPENCLAW_HEALTH_INTERVAL=3

# -----------------------------------------------------------------------------
# vLLM Healthcheck Script (scripts/healthcheck_vllm.sh)
# -----------------------------------------------------------------------------
# Per-request curl timeout (seconds) for the vLLM healthcheck poller.
# This is independent of HEALTHCHECK_CURL_TIMEOUT above.
#VLLM_HEALTH_CURL_TIMEOUT=10

# -----------------------------------------------------------------------------
# OpenClaw Dashboard Healthcheck (scripts/healthcheck_openclaw.sh)
# -----------------------------------------------------------------------------
# Per-request curl timeout (seconds) for OpenClaw polling.
# This is independent of HEALTHCHECK_CURL_TIMEOUT above.
#OPENCLAW_HEALTH_CURL_TIMEOUT=5

# -----------------------------------------------------------------------------
# API Validation Script (scripts/validate-api.sh)
# -----------------------------------------------------------------------------
# Timeout (seconds) for individual curl requests in the API validation script.
#CURL_TIMEOUT=10

# Timeout (seconds) for the POST /v1/chat/completions inference test.
#INFERENCE_TIMEOUT=30

# Set to "true" to skip the inference (POST /v1/chat/completions) test.
# Useful in environments where GPU inference is not available (e.g. CI).
#SKIP_INFERENCE_TEST=false

# -----------------------------------------------------------------------------
# Connection Validation Script (scripts/validate_connection.sh)
# -----------------------------------------------------------------------------
# Number of retry attempts when checking if the vLLM provider is reachable.
#VALIDATE_RETRIES=12

# Seconds to wait between each vLLM connection validation retry.
#VALIDATE_INTERVAL=5

# Per-request curl timeout (seconds) for the connection validation script.
#VALIDATE_TIMEOUT=10

# -----------------------------------------------------------------------------
# GPU Validation (scripts/check-gpu.sh, scripts/lib/gpu.sh)
# -----------------------------------------------------------------------------
# Minimum GPU VRAM in MiB required to run the stack.
# Default is 7500 MiB (~7.5 GB) — sufficient for Qwen2.5-7B AWQ 4-bit.
#MIN_VRAM_MIB=7500

# Minimum NVIDIA kernel driver version required (needed for CUDA >= 11.8).
#MIN_DRIVER_VERSION=520.0

# Minimum CUDA version required by vLLM.
#MIN_CUDA_VERSION=11.8

# -----------------------------------------------------------------------------
# Stop Script
# -----------------------------------------------------------------------------
# Whether to remove the shared network when stopping containers.
# Set to "true" to clean up the network on stop.
#REMOVE_NETWORK=false
