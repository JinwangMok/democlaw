# =============================================================================
# DemoClaw — Environment Configuration
# =============================================================================
# Copy this file to .env and edit as needed:
#   cp .env.example .env
#
# All values below show their defaults. Uncomment and modify to override.
# The .env file is automatically loaded by start.sh.
# =============================================================================

# -----------------------------------------------------------------------------
# Container Runtime
# -----------------------------------------------------------------------------
# Force a specific container runtime. If unset, the scripts auto-detect
# in order: docker, then podman.
# Valid values: docker | podman
#CONTAINER_RUNTIME=docker

# -----------------------------------------------------------------------------
# Network
# -----------------------------------------------------------------------------
# Name of the shared container network connecting llama.cpp and OpenClaw.
#DEMOCLAW_NETWORK=democlaw-net

# -----------------------------------------------------------------------------
# LLM Engine — llama.cpp (CUDA backend)
# -----------------------------------------------------------------------------
# Hardware profile selector. Determines which model & settings to use.
# Valid values: 8gb | dgx-spark
#   8gb       — Gemma 4 E4B Q4_K_M   (~4.7 GB, fits 8 GB VRAM GPUs)
#   dgx-spark — Gemma 4 26B A4B MoE  (128 GB unified memory, DGX Spark)
# When unset, defaults to "8gb".
#HARDWARE_PROFILE=8gb

# HuggingFace repo containing the GGUF model file.
#MODEL_REPO=unsloth/gemma-4-E4B-it-GGUF

# GGUF model filename to download and load.
#MODEL_FILE=gemma-4-E4B-it-Q4_K_M.gguf

# Model alias reported by /v1/models (used by OpenClaw for API requests).
#MODEL_NAME=gemma-4-E4B-it

# Maximum context length in tokens. 131072 (128K) for 8GB VRAM — KV cache
# overflows to host RAM automatically. DGX Spark uses 262144 (256K).
#CTX_SIZE=131072

# Number of model layers offloaded to GPU (99 = all layers).
#N_GPU_LAYERS=99

# Enable flash attention (1=on, 0=off). Saves VRAM.
#FLASH_ATTN=1

# KV cache quantization for keys and values.
# Options: f32, f16, bf16, q8_0, q4_0, q4_1, q5_0, q5_1
# q4_0 aggressively reduces KV cache VRAM — recommended for 8GB VRAM.
# q8_0 is a good balance for high-memory setups.
#CACHE_TYPE_K=q4_0
#CACHE_TYPE_V=q4_0

# -----------------------------------------------------------------------------
# Vision — Multimodal (Gemma 4 Image Input)
# -----------------------------------------------------------------------------
# Enable multimodal vision support. When enabled, the mmproj GGUF file is
# downloaded alongside the model and --mmproj flag is passed to llama-server.
#ENABLE_VISION=1

# Multimodal projector file for vision. Downloaded from MMPROJ_REPO.
#MMPROJ_FILE=mmproj-BF16.gguf

# HuggingFace repo for the mmproj file. Defaults to MODEL_REPO if unset.
#MMPROJ_REPO=

# Gemma 4 vision token budget (70, 140, 280, 560, or 1120). Higher = better quality.
#IMAGE_TOKENS=1120

# Batch sizes — must be >= IMAGE_TOKENS for non-causal attention.
#UBATCH_SIZE=2048
#BATCH_SIZE=2048

# -----------------------------------------------------------------------------
# LLM Engine — Container Settings
# -----------------------------------------------------------------------------
# Docker/Podman image for the llama.cpp container.
#DEMOCLAW_LLAMACPP_IMAGE=docker.io/jinwangmok/democlaw-llamacpp:v2.0.0

# Port the llama.cpp server listens on.
#LLAMACPP_PORT=8000

# Timeout (seconds) to wait for llama.cpp /health endpoint during startup.
# Set higher on first run when the model needs to download (~4.7 GB for E4B).
#LLAMACPP_HEALTH_TIMEOUT=600

# Host directory where GGUF model files are stored and mounted into the container.
#MODEL_DIR=${HOME}/.cache/democlaw/models

# -----------------------------------------------------------------------------
# HuggingFace
# -----------------------------------------------------------------------------
# HuggingFace access token — required only for gated models.
# Gemma 4 GGUF repos (unsloth) are public, so this is not needed.
# Get yours at https://huggingface.co/settings/tokens
#HF_TOKEN=

# -----------------------------------------------------------------------------
# OpenClaw — Container Settings
# -----------------------------------------------------------------------------
# Docker/Podman image for the OpenClaw container.
#DEMOCLAW_OPENCLAW_IMAGE=docker.io/jinwangmok/democlaw-openclaw:v1.3.1

# Port the OpenClaw dashboard listens on.
#OPENCLAW_PORT=18789

# Timeout (seconds) to wait for the OpenClaw dashboard during startup.
#OPENCLAW_HEALTH_TIMEOUT=300

# -----------------------------------------------------------------------------
# OpenClaw — LLM Provider Connection
# -----------------------------------------------------------------------------
# Base URL of the llama.cpp OpenAI-compatible API endpoint (container-internal).
# Uses the container network alias "llamacpp".
#LLAMACPP_BASE_URL=http://llamacpp:8000/v1

# API key for the llama.cpp OpenAI-compatible endpoint.
# When unset, empty, or "EMPTY" / "none": no-auth mode (default).
# When set to a real secret: requires "Authorization: Bearer <key>".
#LLAMA_API_KEY=EMPTY

# Model name to request from llama.cpp. Must match MODEL_NAME above.
#LLAMACPP_MODEL_NAME=gemma-4-E4B-it

# Maximum tokens per LLM response.
#LLAMACPP_MAX_TOKENS=4096

# Sampling temperature (0.0 = deterministic, higher = more random).
#LLAMACPP_TEMPERATURE=0.7

# -----------------------------------------------------------------------------
# OpenClaw — Data Persistence (Optional)
# -----------------------------------------------------------------------------
# Mount a host directory into the OpenClaw container at /home/openclaw/.openclaw
# to persist settings, device pairings, credentials, and agent configs across
# container restarts. Without this, all OpenClaw state is lost on restart.
#OPENCLAW_DATA_DIR=

# -----------------------------------------------------------------------------
# OpenClaw — Workspace Volume Mount (Optional)
# -----------------------------------------------------------------------------
# Mount a host directory into the OpenClaw container at /app/workspace.
# Useful for sharing files between the host and OpenClaw.
# Leave unset to skip the volume mount.
#OPENCLAW_WORKSPACE_DIR=

# -----------------------------------------------------------------------------
# MCP Servers (External Sidecar Containers)
# -----------------------------------------------------------------------------
# MCP servers run as independent containers on the same democlaw-net network.
# See README.md for setup instructions. Example with MarkItDown:
#
#   docker build -t democlaw-markitdown:latest ./markitdown
#   docker run -d --name markitdown --network democlaw-net \
#     --network-alias markitdown -p 3001:3001 \
#     democlaw-markitdown:latest
#
# Then register in config/mcporter.json and restart OpenClaw.

# -----------------------------------------------------------------------------
# GPU Validation
# -----------------------------------------------------------------------------
# Minimum GPU VRAM in MiB required to run the stack.
# Default is 7000 MiB (~6.8 GB) — sufficient for Gemma 4 E4B Q4_K_M GGUF.
#MIN_VRAM_MIB=7000

# Minimum NVIDIA kernel driver version (CUDA 12.x compatible).
#MIN_DRIVER_VERSION=525.0

# -----------------------------------------------------------------------------
# Stop Script
# -----------------------------------------------------------------------------
# Whether to remove the shared network when stopping containers.
#REMOVE_NETWORK=false
