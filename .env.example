# =============================================================================
# DemoClaw — Environment Configuration
# =============================================================================
# Copy this file to .env and edit as needed:
#   cp .env.example .env
#
# All values below show their defaults. Uncomment and modify to override.
# The .env file is automatically loaded by start.sh.
# =============================================================================

# -----------------------------------------------------------------------------
# Container Runtime
# -----------------------------------------------------------------------------
# Force a specific container runtime. If unset, the scripts auto-detect
# in order: docker, then podman.
# Valid values: docker | podman
#CONTAINER_RUNTIME=docker

# -----------------------------------------------------------------------------
# Network
# -----------------------------------------------------------------------------
# Name of the shared container network connecting llama.cpp and OpenClaw.
#DEMOCLAW_NETWORK=democlaw-net

# -----------------------------------------------------------------------------
# LLM Engine — llama.cpp (CUDA backend)
# -----------------------------------------------------------------------------
# HuggingFace repo containing the GGUF model file.
#MODEL_REPO=unsloth/Qwen3.5-9B-GGUF

# GGUF model filename to download and load.
#MODEL_FILE=Qwen3.5-9B-Q4_K_M.gguf

# Model alias reported by /v1/models (used by OpenClaw for API requests).
#MODEL_NAME=Qwen3.5-9B-Q4_K_M

# Maximum context length in tokens. 32768 fits in 8GB VRAM.
# Set to 65536 for 64k context (may use ~1-2 GB host RAM offloading).
#CTX_SIZE=32768

# Number of model layers offloaded to GPU (99 = all layers).
#N_GPU_LAYERS=99

# Enable flash attention (1=on, 0=off). Saves VRAM.
#FLASH_ATTN=1

# KV cache quantization for keys and values.
# Options: f32, f16, bf16, q8_0, q4_0, q4_1, q5_0, q5_1
# q8_0 halves KV cache VRAM with minimal quality loss.
#CACHE_TYPE_K=q8_0
#CACHE_TYPE_V=q8_0

# -----------------------------------------------------------------------------
# LLM Engine — Container Settings
# -----------------------------------------------------------------------------
# Docker/Podman image for the llama.cpp container.
#DEMOCLAW_LLAMACPP_IMAGE=docker.io/jinwangmok/democlaw-llamacpp:v1.1.0

# Port the llama.cpp server listens on.
#LLAMACPP_PORT=8000

# Timeout (seconds) to wait for llama.cpp /health endpoint during startup.
# Set higher on first run when the model needs to download (~5.7 GB).
#LLAMACPP_HEALTH_TIMEOUT=600

# Host directory where GGUF model files are stored and mounted into the container.
#MODEL_DIR=${HOME}/.cache/democlaw/models

# -----------------------------------------------------------------------------
# HuggingFace
# -----------------------------------------------------------------------------
# HuggingFace access token — required only for gated models.
# Qwen3.5-9B-GGUF is public, so this is not needed.
# Get yours at https://huggingface.co/settings/tokens
#HF_TOKEN=

# -----------------------------------------------------------------------------
# OpenClaw — Container Settings
# -----------------------------------------------------------------------------
# Docker/Podman image for the OpenClaw container.
#DEMOCLAW_OPENCLAW_IMAGE=docker.io/jinwangmok/democlaw-openclaw:v1.1.0

# Port the OpenClaw dashboard listens on.
#OPENCLAW_PORT=18789

# Timeout (seconds) to wait for the OpenClaw dashboard during startup.
#OPENCLAW_HEALTH_TIMEOUT=120

# -----------------------------------------------------------------------------
# OpenClaw — LLM Provider Connection
# -----------------------------------------------------------------------------
# Base URL of the llama.cpp OpenAI-compatible API endpoint (container-internal).
# Uses the container network alias "llamacpp".
#LLAMACPP_BASE_URL=http://llamacpp:8000/v1

# API key for the llama.cpp OpenAI-compatible endpoint.
# When unset, empty, or "EMPTY" / "none": no-auth mode (default).
# When set to a real secret: requires "Authorization: Bearer <key>".
#LLAMA_API_KEY=EMPTY

# Model name to request from llama.cpp. Must match MODEL_NAME above.
#LLAMACPP_MODEL_NAME=Qwen3.5-9B-Q4_K_M

# Maximum tokens per LLM response.
#LLAMACPP_MAX_TOKENS=4096

# Sampling temperature (0.0 = deterministic, higher = more random).
#LLAMACPP_TEMPERATURE=0.7

# -----------------------------------------------------------------------------
# MarkItDown MCP Server — Document Conversion Sidecar
# -----------------------------------------------------------------------------
# Docker/Podman image for the MarkItDown MCP server container.
#DEMOCLAW_MARKITDOWN_IMAGE=docker.io/jinwangmok/democlaw-markitdown:v1.1.0

# Port the MarkItDown MCP server listens on.
#MARKITDOWN_PORT=3001

# -----------------------------------------------------------------------------
# GPU Validation
# -----------------------------------------------------------------------------
# Minimum GPU VRAM in MiB required to run the stack.
# Default is 7500 MiB (~7.5 GB) — sufficient for Qwen3.5-9B Q4_K_M GGUF.
#MIN_VRAM_MIB=7500

# Minimum NVIDIA kernel driver version (CUDA 12.x compatible).
#MIN_DRIVER_VERSION=525.0

# -----------------------------------------------------------------------------
# Stop Script
# -----------------------------------------------------------------------------
# Whether to remove the shared network when stopping containers.
#REMOVE_NETWORK=false
