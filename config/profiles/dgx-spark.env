# =============================================================================
# DemoClaw — DGX Spark Deployment Profile
# =============================================================================
# Gemma 4 26B A4B (MoE) on NVIDIA DGX Spark (128GB unified memory)
#
# Model : Google Gemma 4 26B A4B Instruct (Mixture of Experts)
# Format: safetensors (FP8 quantization via vLLM)
# Source: https://huggingface.co/google/gemma-4-26B-A4B-it
# Target: NVIDIA DGX Spark — Grace Blackwell, 128GB unified CPU+GPU memory
#
# Usage:
#   1. Copy to .env at project root:
#        cp config/profiles/dgx-spark.env .env
#   2. Or source alongside your base .env:
#        cat config/profiles/dgx-spark.env >> .env
#   3. Then start normally:
#        make start   OR   ./scripts/start.sh
#
# Architecture notes:
#   - Gemma 4 26B A4B is a Mixture-of-Experts model (4 active out of ~N experts)
#   - vLLM serves the model in FP8 quantization from safetensors format
#   - gpu_memory_utilization=0.70 uses ~90GB of 128GB unified memory
#   - 262144-token context window enabled with FP8 KV cache
#   - Vision is handled natively by vLLM (no separate mmproj required)
#   - Prefix caching and chunked prefill enabled for throughput
# =============================================================================

# -----------------------------------------------------------------------------
# LLM Engine — Primary Setting
# -----------------------------------------------------------------------------
LLM_ENGINE=vllm

# -----------------------------------------------------------------------------
# vLLM — Serving Configuration
# -----------------------------------------------------------------------------
# Docker image with vLLM built for CUDA 13.0 + Gemma 4 support.
VLLM_IMAGE=vllm/vllm-openai:gemma4-cu130

# HuggingFace model ID to load (safetensors, gated repo — HF_TOKEN required).
VLLM_MODEL_ID=google/gemma-4-26B-A4B-it

# Port vLLM OpenAI-compatible server listens on.
VLLM_PORT=8000

# Fraction of GPU memory vLLM may allocate for weights + KV cache.
# 0.70 on DGX Spark's 128GB unified memory pool ≈ ~90GB allocated.
VLLM_GPU_MEM_UTIL=0.70

# FP8 weight quantization — reduces memory footprint with minimal quality loss
# on Blackwell (GB10) hardware that has native FP8 tensor core support.
VLLM_QUANTIZATION=fp8

# Additional vLLM server arguments:
#   --kv-cache-dtype fp8          FP8 KV cache to reduce memory usage at long context
#   --load-format safetensors     Load model weights from safetensors files
#   --enable-auto-tool-choice     Enable automatic tool/function call handling
#   --tool-call-parser gemma4     Gemma 4-specific tool call parser
#   --reasoning-parser gemma4     Gemma 4-specific reasoning/thinking parser
#   --enable-prefix-caching       Cache common prompt prefixes for throughput
#   --enable-chunked-prefill      Chunked prefill for large context requests
#   --max-num-seqs 4              Max concurrent sequences (tuned for DGX Spark)
#   --max-num-batched-tokens 8192 Max tokens processed per batch step
VLLM_EXTRA_ARGS=--kv-cache-dtype fp8 --load-format safetensors --enable-auto-tool-choice --tool-call-parser gemma4 --reasoning-parser gemma4 --enable-prefix-caching --enable-chunked-prefill --max-num-seqs 4 --max-num-batched-tokens 8192

# Maximum sequence length vLLM will accept (tokens).
# Gemma 4 supports up to 262144 tokens; DGX Spark's 128GB unified memory
# with FP8 KV cache can sustain this window.
VLLM_MAX_MODEL_LEN=262144

# Timeout (seconds) for the vLLM health endpoint during startup.
# First launch downloads safetensors weights from HuggingFace — allow 1 hour.
VLLM_HEALTH_TIMEOUT=3600

# -----------------------------------------------------------------------------
# OpenClaw — LLM Provider Connection
# -----------------------------------------------------------------------------
# Model alias reported by /v1/models and used by OpenClaw for API requests.
MODEL_NAME=gemma-4-26B-A4B-it

# Model name sent in API requests from OpenClaw. Must match MODEL_NAME above.
LLAMACPP_MODEL_NAME=gemma-4-26B-A4B-it

# Maximum tokens per LLM response.
# Gemma 4 supports long-form generation; 8192 allows detailed responses.
LLAMACPP_MAX_TOKENS=8192

# Sampling temperature.
LLAMACPP_TEMPERATURE=0.7

# -----------------------------------------------------------------------------
# Model cache directory (host path mounted into the vLLM container)
# -----------------------------------------------------------------------------
# DGX Spark ships with /data on the NVMe pool. Pinning MODEL_DIR here ensures
# the 50+ GB Gemma 4 safetensors shards land on fast storage AND can be
# shared with sibling toolchains (e.g. dgx-spark-ai-cluster's dgx-vllm) that
# already cache weights at /data/models — avoiding a full re-download on the
# first democlaw start and eliminating slow-disk mmap stalls during load.
MODEL_DIR=/data/models

# -----------------------------------------------------------------------------
# HuggingFace
# -----------------------------------------------------------------------------
# Gemma 4 models are gated — a HuggingFace token is required for download.
# Get yours at https://huggingface.co/settings/tokens
# Accept the license at https://huggingface.co/google/gemma-4-26b-a4b-it
#HF_TOKEN=

# -----------------------------------------------------------------------------
# GPU Validation
# -----------------------------------------------------------------------------
# DGX Spark has 128GB unified memory. Set minimum VRAM threshold to 16 GB
# to pass the pre-flight GPU check.
# Note: nvidia-smi on DGX Spark reports the full unified memory pool.
MIN_VRAM_MIB=16000

# DGX Spark ships with CUDA 12.x compatible drivers.
MIN_DRIVER_VERSION=550.0

# -----------------------------------------------------------------------------
# Legacy: llama.cpp — commented out for rollback reference
# -----------------------------------------------------------------------------
# [legacy: llama.cpp] MODEL_REPO=unsloth/gemma-4-26B-A4B-it-GGUF
# [legacy: llama.cpp] MODEL_FILE=gemma-4-26B-A4B-it-Q8_0.gguf
# [legacy: llama.cpp] CTX_SIZE=262144
# [legacy: llama.cpp] N_GPU_LAYERS=99
# [legacy: llama.cpp] FLASH_ATTN=1
# [legacy: llama.cpp] CACHE_TYPE_K=q8_0
# [legacy: llama.cpp] CACHE_TYPE_V=q8_0
