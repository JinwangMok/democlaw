# =============================================================================
# DemoClaw — DGX Spark Deployment Profile
# =============================================================================
# Gemma 4 26B A4B (MoE) on NVIDIA DGX Spark (128GB unified memory)
#
# Model : Google Gemma 4 26B A4B Instruct (Mixture of Experts)
# Format: GGUF Q4_K_M quantization (~15-16 GB on disk)
# Source: https://huggingface.co/unsloth/gemma-4-26B-A4B-it-GGUF
# Target: NVIDIA DGX Spark — Grace Blackwell, 128GB unified CPU+GPU memory
#
# Usage:
#   1. Copy to .env at project root:
#        cp config/profiles/dgx-spark.env .env
#   2. Or source alongside your base .env:
#        cat config/profiles/dgx-spark.env >> .env
#   3. Then start normally:
#        make start   OR   ./scripts/start.sh
#
# Architecture notes:
#   - Gemma 4 26B A4B is a Mixture-of-Experts model (4 active out of ~N experts)
#   - At Q4_K_M quantization, model weights are ~15-16 GB
#   - DGX Spark's 128GB unified memory allows full GPU offload + large context
#   - 128k context window is feasible with KV cache quantization (q8_0)
#   - All layers offloaded to GPU (N_GPU_LAYERS=99) for maximum throughput
#   - Flash attention enabled to reduce KV cache memory footprint
# =============================================================================

# -----------------------------------------------------------------------------
# LLM Engine — Gemma 4 26B A4B MoE (llama.cpp GGUF)
# -----------------------------------------------------------------------------
# HuggingFace repo containing the GGUF model file.
MODEL_REPO=unsloth/gemma-4-26B-A4B-it-GGUF

# GGUF model filename — Q4_K_M quantization (~15-16 GB).
# Fits comfortably in DGX Spark's 128GB unified memory with room for large KV cache.
MODEL_FILE=gemma-4-26B-A4B-it-Q4_K_M.gguf

# Model alias reported by /v1/models (used by OpenClaw for API requests).
MODEL_NAME=gemma-4-26B-A4B-it

# Maximum context length in tokens.
# DGX Spark's 128GB unified memory supports 128k context with Q4_K_M weights
# and q8_0 KV cache quantization. Memory budget:
#   - Model weights (Q4_K_M):  ~15-16 GB
#   - KV cache (q8_0, 128k):   ~20-25 GB (estimated for 26B MoE architecture)
#   - Compute scratch/buffers:  ~5-10 GB
#   - Total estimated:          ~40-51 GB (well within 128GB)
#
# Use 65536 for conservative deployments or if running other workloads.
CTX_SIZE=131072

# Offload all model layers to GPU for maximum inference throughput.
# DGX Spark's unified memory architecture means GPU and CPU share the same
# physical memory — setting this to 99 ensures all layers use GPU compute.
N_GPU_LAYERS=99

# Enable flash attention to reduce KV cache memory consumption.
# Critical for large context windows — reduces KV cache memory by ~2-4x
# compared to standard attention.
FLASH_ATTN=1

# KV cache quantization for keys and values.
# q8_0 provides ~2x memory savings with negligible quality impact.
# For 128k context on 128GB unified memory, q8_0 is the sweet spot between
# quality and memory efficiency.
#
# Alternative: use q4_0 for keys if memory pressure occurs with very long
# contexts + concurrent requests, but q8_0 is preferred for quality.
CACHE_TYPE_K=q8_0
CACHE_TYPE_V=q8_0

# -----------------------------------------------------------------------------
# LLM Engine — Container Settings
# -----------------------------------------------------------------------------
# Port the llama.cpp server listens on (unchanged from default).
LLAMACPP_PORT=8000

# Timeout for llama.cpp health endpoint during startup.
# Gemma 4 26B A4B GGUF is ~15-16 GB; first download may take several minutes.
# On DGX Spark's NVLink/high-bandwidth memory, model loading is fast once cached.
LLAMACPP_HEALTH_TIMEOUT=900

# Host directory where GGUF model files are stored and mounted into the container.
# DGX Spark typically has fast NVMe storage; adjust to local storage path.
#MODEL_DIR=${HOME}/.cache/democlaw/models

# -----------------------------------------------------------------------------
# HuggingFace
# -----------------------------------------------------------------------------
# Gemma 4 models are gated — a HuggingFace token is required for download.
# Get yours at https://huggingface.co/settings/tokens
# Accept the license at https://huggingface.co/google/gemma-4-26b-a4b-it
#HF_TOKEN=

# -----------------------------------------------------------------------------
# OpenClaw — LLM Provider Connection
# -----------------------------------------------------------------------------
# Model name sent to llama.cpp in API requests. Must match MODEL_NAME above.
LLAMACPP_MODEL_NAME=gemma-4-26B-A4B-it

# Maximum tokens per LLM response.
# Gemma 4 supports long-form generation; 8192 allows detailed responses.
LLAMACPP_MAX_TOKENS=8192

# Sampling temperature.
LLAMACPP_TEMPERATURE=0.7

# -----------------------------------------------------------------------------
# GPU Validation
# -----------------------------------------------------------------------------
# DGX Spark has 128GB unified memory. Set minimum VRAM threshold to 16 GB
# (model weights footprint) to pass the pre-flight GPU check.
# Note: nvidia-smi on DGX Spark reports the full unified memory pool.
MIN_VRAM_MIB=16000

# DGX Spark ships with CUDA 12.x compatible drivers.
MIN_DRIVER_VERSION=550.0
