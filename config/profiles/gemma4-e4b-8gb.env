# =============================================================================
# DemoClaw — 8GB VRAM Deployment Profile
# =============================================================================
# Gemma 4 E4B on consumer GPUs with 8GB VRAM (RTX 3070/4070 class)
#
# Model : Google Gemma 4 E4B Instruct (efficient 4B parameter model)
# Format: GGUF Q4_K_M quantization (~4.7 GB on disk)
# Source: https://huggingface.co/unsloth/gemma-4-E4B-it-GGUF
# Target: Consumer GPUs with 8GB VRAM (e.g., RTX 3070, RTX 4070, RTX 3060 8GB)
#
# Usage:
#   1. Copy to .env at project root:
#        cp config/profiles/gemma4-e4b-8gb.env .env
#   2. Then start normally:
#        make start   OR   ./scripts/start.sh
#
# Memory budget (8GB VRAM):
#   - Model weights (Q4_K_M):  ~4.7 GB
#   - KV cache (q4_0, 8k):     ~0.5-1 GB
#   - Compute scratch/buffers:  ~1-2 GB
#   - Total estimated:          ~4-6 GB (fits comfortably in 8GB VRAM)
#
# For higher context (32k+), switch to q8_0 KV cache, but monitor VRAM usage.
# =============================================================================

# -----------------------------------------------------------------------------
# LLM Engine — Gemma 4 E4B (llama.cpp GGUF)
# -----------------------------------------------------------------------------
# HuggingFace repo containing the GGUF model file.
MODEL_REPO=unsloth/gemma-4-E4B-it-GGUF

# GGUF model filename — Q4_K_M quantization (~4.7 GB).
MODEL_FILE=gemma-4-E4B-it-Q4_K_M.gguf

# Model alias reported by /v1/models (used by OpenClaw for API requests).
MODEL_NAME=gemma-4-E4B-it

# Maximum context length in tokens.
# 8192 fits comfortably within 8GB VRAM budget with q4_0 KV cache.
# Can increase to 32768 if using q4_0 KV cache and monitoring VRAM closely.
CTX_SIZE=131072

# Offload all model layers to GPU.
N_GPU_LAYERS=99

# Enable flash attention to reduce KV cache VRAM usage.
FLASH_ATTN=1

# KV cache quantization — q4_0 aggressively reduces KV cache VRAM usage.
# Use q8_0 if you have VRAM headroom and want higher quality.
CACHE_TYPE_K=q4_0
CACHE_TYPE_V=q4_0

# -----------------------------------------------------------------------------
# LLM Engine — Container Settings
# -----------------------------------------------------------------------------
LLAMACPP_PORT=8000
LLAMACPP_HEALTH_TIMEOUT=600

# -----------------------------------------------------------------------------
# HuggingFace
# -----------------------------------------------------------------------------
# Gemma 4 models may be gated — a HuggingFace token may be required.
# Get yours at https://huggingface.co/settings/tokens
#HF_TOKEN=

# -----------------------------------------------------------------------------
# OpenClaw — LLM Provider Connection
# -----------------------------------------------------------------------------
LLAMACPP_MODEL_NAME=gemma-4-E4B-it
LLAMACPP_MAX_TOKENS=4096
LLAMACPP_TEMPERATURE=0.7

# -----------------------------------------------------------------------------
# GPU Validation
# -----------------------------------------------------------------------------
# Minimum ~6.8 GB VRAM — sufficient for Gemma 4 E4B Q4_K_M with 8k context.
MIN_VRAM_MIB=7000
MIN_DRIVER_VERSION=525.0
